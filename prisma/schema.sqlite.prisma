generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// The rest of the schema is the same as schema.prisma - copy models

// --- models copied from schema.prisma ---

enum UserRole {
  MEMBER
  ADMIN
}

enum WalletTransactionType {
  TOPUP
  ORDER_PAYMENT
  REFUND
  ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PROCESSING
  IN_PROGRESS
  PARTIAL
  COMPLETED
  CANCELED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  fullName       String
  username       String?             @unique
  phone          String?
  role           UserRole            @default(MEMBER)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  wallet         Wallet?
  walletEntries  WalletTransaction[]
  orders         Order[]
  payments       Payment[]
  tickets        Ticket[]
  notifications  Notification[]
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  currency  String   @default("IDR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id          String                  @id @default(cuid())
  userId      String
  type        WalletTransactionType
  status      WalletTransactionStatus @default(PENDING)
  amount      Int
  balanceAfter Int?
  currency    String                  @default("IDR")
  reference   String?
  note        String?
  metadata    Json?
  createdAt   DateTime                @default(now())
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reference])
}

model Service {
  id                  String   @id @default(cuid())
  provider            String   @default("smmwiz")
  providerServiceId   String   @unique
  name                String
  category            String
  type                String?
  min                 Int
  max                 Int
  providerRateUsdPer1k Decimal @db.Decimal(12, 6)
  retailPricePer1k    Int
  refill              Boolean  @default(false)
  cancel              Boolean  @default(false)
  isActive            Boolean  @default(true)
  raw                 Json?
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  orders              Order[]

  @@index([category])
  @@index([isActive])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  provider        String        @default("manual")
  providerPaymentId String?
  status          PaymentStatus @default(PENDING)
  amount          Int
  fee             Int           @default(0)
  currency        String        @default("IDR")
  method          String
  invoiceUrl      String?
  paidAt          DateTime?
  expiredAt       DateTime?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([providerPaymentId])
}

model Order {
  id                String      @id @default(cuid())
  publicId          String      @unique
  userId            String
  serviceId         String
  paymentId         String?
  provider          String      @default("smmwiz")
  providerOrderId   String?
  link              String
  quantity          Int
  charge            Int
  providerCostIdr   Int?
  profitIdr         Int?
  startCount        Int?
  remains           Int?
  status            OrderStatus @default(PENDING)
  rawStatus         String?
  note              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  service           Service     @relation(fields: [serviceId], references: [id])
  payment           Payment?    @relation(fields: [paymentId], references: [id])
  tickets           Ticket[]

  @@index([userId, createdAt])
  @@index([providerOrderId])
  @@index([status])
}

model Ticket {
  id          String         @id @default(cuid())
  publicId    String         @unique
  userId      String
  orderId     String?
  subject     String
  category    String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  messages    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?         @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}
